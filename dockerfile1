# ===============================
# 第一阶段：编译 Nginx + http-flv
# ===============================
FROM alpine:3.20 AS builder

ARG NGINX_VERSION=1.28.0
ARG FLV_VERSION=1.2.12
# 安装编译依赖
RUN sed -i 's#https\?://dl-cdn.alpinelinux.org/alpine#https://mirrors.aliyun.com/alpine#g' /etc/apk/repositories \
    && apk add --no-cache \
    build-base \
    linux-headers \
    pcre2-dev \
    zlib-dev \
    openssl-dev \
    wget \
    git \
    libxslt-dev \
    bash

WORKDIR /build

# 下载 nginx
RUN wget https://nginx.org/download/nginx-${NGINX_VERSION}.tar.gz && \
    tar zxvf nginx-${NGINX_VERSION}.tar.gz

# 下载 nginx-http-flv-module
RUN git clone https://github.com/winshining/nginx-http-flv-module.git

WORKDIR /build/nginx-${NGINX_VERSION}

# 配置并编译
RUN ./configure \
    --prefix=/etc/nginx \
    --sbin-path=/usr/sbin/nginx \
    --conf-path=/etc/nginx/nginx.conf \
    --add-module=/build/nginx-http-flv-module \
    --with-http_xslt_module \
    --with-http_stub_status_module \
    --with-http_ssl_module \
    --with-http_realip_module \
    --with-http_sub_module \
    --with-stream \
    --with-stream_ssl_module \
    && make -j$(nproc) \
    && make install

# ===============================
# 第二阶段：运行环境
# ===============================
FROM alpine:3.20
ENV TZ=Asia/Shanghai
RUN cat > "/usr/local/bin/push.sh" << EOF
#!/bin/sh
sleep 3
clear

# 颜色
RED='\033[1;31m'        # 鲜红
PINK='\033[1;35m'       # 亮紫
CYAN='\033[1;36m'       # 亮青
GREEN='\033[1;32m'      # 亮绿
YELLOW='\033[1;33m'     # 亮黄
BLUE='\033[1;34m'       # 亮蓝
WHITE='\033[1;37m'      # 亮白
NC='\033[0m'            # 清除颜色


WARN() { echo -e "${RED}[$(date +'%Y-%m-%d %H:%M:%S')] WARN: $1${NC}"; }
INFO() { echo -e "${GREEN}[$(date +'%Y-%m-%d %H:%M:%S')] INFO: $1${NC}"; }
NOTIME() { echo -e "${GREEN}--> INFO: $1${NC}"; }

# ======================
# 基础设置 sh 版本
# ======================
VIDEO_DIR="/media"
STREAM_KEY="${STREAM_KEY:-video}"
RTMP_URL="rtmp://localhost:1935/hls/$STREAM_KEY"
INFO "初始化 HLS 输出目录..."
rm -rf /opt/data/hls/*

INFO "自动推流脚本启动，监控目录: $VIDEO_DIR"

get_media_info() {
    FILE="$1"

    # 视频编码（取第一个视频流）
    VIDEO_CODEC=$(ffprobe -v error \
        -select_streams v:0 \
        -show_entries stream=codec_name \
        -of default=noprint_wrappers=1:nokey=1 \
        "$FILE")

    # 音频编码（取第一个音频流）
    AUDIO_CODEC=$(ffprobe -v error \
        -select_streams a:0 \
        -show_entries stream=codec_name \
        -of default=noprint_wrappers=1:nokey=1 \
        "$FILE")

    # 防止空值
    [ -z "$VIDEO_CODEC" ] && VIDEO_CODEC="unknown"
    [ -z "$AUDIO_CODEC" ] && AUDIO_CODEC="unknown"

    NOTIME "视频流编码-> $VIDEO_CODEC"
    NOTIME "音频流编码-> $AUDIO_CODEC"
}

while true; do
    INFO "扫描 mp4 文件..."
    mp4_list="/tmp/mp4_list.txt"
    find "$VIDEO_DIR" -type f \( \
        -name "*.mp4" -o -name "*.mkv" -o -name "*.avi" \
        -o -name "*.mov" -o -name "*.m4v" -o -name "*.flv" \
        -o -name "*.wmv" -o -name "*.mpeg" -o -name "*.mpg" \
        -o -name "*.ts" -o -name "*.m2ts" -o -name "*.webm" \
    \) | sort > "$mp4_list"

    if [ ! -s "$mp4_list" ]; then
        WARN "没有发现 mp4 文件，3 秒后重试..."
        sleep 3
        continue
    fi

    INFO "视频文件列表数量: $(wc -l < "$mp4_list")"

    # ======================
    # 读取每行到单独变量
    # ======================
    FILE_NUM=0
    while IFS= read -r line || [ -n "$line" ]; do
        # 去掉可能的 \r
        line=$(printf '%s' "$line" | tr -d '\r')
        FILE_NUM=$((FILE_NUM+1))
        eval "FILE$FILE_NUM=\$line"
    done < "$mp4_list"
    i=1
    while [ $i -le $FILE_NUM ]; do
        eval "mp4file=\$FILE$i"

        INFO "====================================================="
        INFO "当前文件: $mp4file"

        if [ ! -f "$mp4file" ]; then
            WARN "[ERROR] 文件不存在: $mp4file"
            i=$((i+1))
            continue
        fi

        # 检查编码
        get_media_info "$mp4file"
        if [ "$VIDEO_CODEC" != "h264" ] || [ "$AUDIO_CODEC" != "aac" ]; then
            WARN "[SKIP] 跳过: 此编码不合适 $VIDEO_CODEC $AUDIO_CODEC"
            i=$((i+1))
            continue
        fi

        NOTIME "视频编码 OK"
        NOTIME "开始推流..."
        ffmpeglog="/tmp/ffmpeg_$(date +'%F').log"

        ffmpeg -re -i "$mp4file" -c copy -f flv "$RTMP_URL" >>"$ffmpeglog" 2>&1

        INFO "播放完成，等待 3 秒..."
        sleep 3
        i=$((i+1))
    done

    INFO "全部文件播放完毕，3 秒后重新开始..."
    sleep 3
    nginx -s reload
    INFO "初始化 HLS 输出目录..."
    rm -rf /opt/data/hls/*
done
EOF

# 运行时依赖
RUN sed -i 's#https\?://dl-cdn.alpinelinux.org/alpine#https://mirrors.aliyun.com/alpine#g' /etc/apk/repositories \
    && apk add --no-cache \
    pcre2 \
    zlib \
    openssl \
    ca-certificates \
    ffmpeg \
    libxslt \
    libxml2 \
    tzdata && \
    mkdir -p /var/log/nginx /var/run/nginx \
    && cp /usr/share/zoneinfo/$TZ /etc/localtime \
    && echo "$TZ" > /etc/timezone \
    && rm -rf /media/* && mkdir -p /opt/data/hls && chmod +x /usr/local/bin/push.sh
    

# 从 builder 拷贝 nginx
COPY --from=builder /usr/sbin/nginx /usr/sbin/nginx
COPY --from=builder /etc/nginx /etc/nginx
COPY --from=builder /build/nginx-http-flv-module/stat.xsl /www/static/

RUN cat > "/etc/nginx/nginx.conf" << EOF
worker_processes  1;

error_log /dev/stdout info;

events {
    worker_connections 1024;
}

rtmp {
    server {
        listen 1935;
        chunk_size 4096;

        application hls {
            live on;
            hls on;
            hls_fragment_naming system;
            hls_fragment 2;
            hls_playlist_length 30;
            hls_path /opt/data/hls;
            hls_nested off;

        }
        
        application flv {
            live on;
        }
        
        
    }
}

http {
    root /www/static;
    sendfile off;
    tcp_nopush on;
    server_tokens off;
    access_log /dev/stdout combined;

    server {
        listen 8080;
        
        location = / {
            index index.html;
        }

        location /hls {
            alias /opt/data/hls;
            types {
                application/vnd.apple.mpegurl m3u8;
                video/mp2t ts;
            }
            add_header Cache-Control no-cache;
            add_header Access-Control-Allow-Origin *;

        #    if ($http_user_agent != "chengji.m3u8") {
        #        return 403;
        #    }
        }
        
        location /flv {
            flv_live on;
            add_header Access-Control-Allow-Origin *;
            add_header Cache-Control no-cache;
        }

        location /stat {
            rtmp_stat all;
            rtmp_stat_stylesheet stat.xsl;
        }

        location /stat.xsl {
            root /www/static;
        }
    }
}
EOF

RUN cat > "/www/static/index.html" << EOF
<div id="dplayer"></div>
<script src="https://registry.npmmirror.com/dplayer/1.27.0/files/dist/DPlayer.min.js"></script>
<script src="https://registry.npmmirror.com/hls.js/1.5.7/files/dist/hls.min.js"></script>

<script>
    const dp = new DPlayer({
        container: document.getElementById('dplayer'),
        autoplay: true,
        theme: "#00a1d6",
        video: {
            url: 'hls/video.m3u8',
            type: 'customHls',
            customType: {
                customHls: function (video, player) {
                    if (Hls.isSupported()) {
                        const hls = new Hls();
                        hls.loadSource(video.src);
                        hls.attachMedia(video);
                    } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                        video.src = video.src;
                    }
                }
            }
        }
    });
</script>
</html>
EOF


EXPOSE 80 443 1935 8080

STOPSIGNAL SIGQUIT

CMD /bin/sh /usr/local/bin/push.sh & nginx -g "daemon off;"
